# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=openai/gpt-4.1

# Plano gateway (optional). When set, LLM calls route through a local Plano
# proxy (https://github.com/katanemo/plano) which proxies to OpenRouter and
# computes model-free Signals. Leave empty to call OpenRouter directly.
# Start Plano: planoai up backend/plano_config.yaml --with-tracing
# PLANO_GATEWAY_URL=http://localhost:12000/v1

# Tavily (https://app.tavily.com)
TAVILY_API_KEY=tvly-xxx

# PostHog (https://app.posthog.com/settings/project)
POSTHOG_API_KEY=phc_xxx
POSTHOG_OTEL_ENDPOINT=https://us.i.posthog.com/i/v0/ai/otel
